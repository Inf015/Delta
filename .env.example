# ─── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=simtelemetry
POSTGRES_USER=simtelemetry
# Generar con: openssl rand -base64 24
POSTGRES_PASSWORD=changeme

# ─── API / Auth ────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
# Orígenes CORS permitidos (separados por coma, sin espacios)
# Dev: http://localhost:3000
# Prod: https://tudominio.com
ALLOWED_ORIGINS=http://localhost:3000
# Entorno: development | production
ENVIRONMENT=development

# ─── Anthropic ─────────────────────────────────────────────────────────────────
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Drive (opcional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# En producción usar HTTPS y dominio real: https://api.tudominio.com/api/drive/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/drive/callback

# ─── Stripe (opcional) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# ─── Frontend ──────────────────────────────────────────────────────────────────
# URL pública de la API (se bake en el bundle de Next.js al hacer build)
# Dev: http://localhost:8000
# Prod: https://tudominio.com  (el mismo dominio si nginx hace proxy)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Pool de base de datos (opcional, defaults razonables) ─────────────────────
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=5
# DB_POOL_RECYCLE=1800
